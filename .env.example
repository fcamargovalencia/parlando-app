# ── ParlAndo App Environment Variables ──
# Copy to .env and fill in values

# API base URL (no trailing slash)
EXPO_PUBLIC_API_URL=https://ecommerce-api.wittysky-ae597b7e.westus2.azurecontainerapps.io

# AES-256 key (Base64-encoded 32-byte key) — must match parlando-api
EXPO_PUBLIC_AES_KEY=

EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=preset
